# ── Supabase ────────────────────────────────────────────────
# From Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key here (secret, server-side only — never put it in the web app)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email alerts (Gmail) ────────────────────────────────────
# Turn on 2FA on the Gmail account, then create an App Password:
#   https://myaccount.google.com/apppasswords
# Put the 16-char app password below (NOT your normal Gmail password).
EMAIL_ENABLED=true
EMAIL_FROM=hebahesham102@gmail.com
EMAIL_TO=hebahesham102@gmail.com
GMAIL_USER=hebahesham102@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ── Scraper behaviour ───────────────────────────────────────
# How often to check, in minutes. 1 = every minute (aggressive — see README warning).
CHECK_INTERVAL_MINUTES=1
# Random extra delay (0..N seconds) added to each run so the timing isn't robotic.
# Helps avoid Facebook's automation detection. Recommended: 20-45.
CHECK_JITTER_SECONDS=30
# Set to "false" to watch the browser work (useful first time / debugging).
HEADLESS=true
